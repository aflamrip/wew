---
// src/components/PlayerIsland.astro
import PlyrComponent from './Plyr.svelte';
import { getPrefix, getVideoDomain } from '../lib/constants';
import { fetchCdnNdjson, fetchSeasonNdjson } from '../lib/cf-bindings';

interface Props {
  type: 'movie' | 'tv';
  prefix?: string;
  id: string;
  season?: string;
  episode?: string;
  /** Content language — subtitles are only loaded for foreign (non-Arabic) content */
  lang?: string;
}

const { type, prefix: prefixProp, id, season, episode, lang = 'ar' } = Astro.props;
const prefix = prefixProp || getPrefix(id);

let videoUrl    = '';
let subtitleUrl = '';

// Determine if this is foreign content (non-Arabic).
// ar.vtt subtitles are only served for foreign movies/series.
const isForeign = lang !== 'ar';

try {
  const isMovie      = type === 'movie' || type === 'movies';
  const pluralType   = isMovie ? 'movies' : 'tv';
  const seasonPadded = season ? season.padStart(2, '0') : '01';

  // Fetch metadata via R2/KV binding
  let dataText: string | null = null;

  if (type === 'tv' && season) {
    dataText = await fetchSeasonNdjson(prefix, id, seasonPadded);
  } else {
    dataText = await fetchCdnNdjson(pluralType as 'movies' | 'tv', prefix, id);
  }

  if (dataText) {
    const lines = dataText
      .split('\n')
      .filter(l => l.trim().length > 0);

    let data: any;
    if (type === 'tv' && episode) {
      data = lines
        .map(l => { try { return JSON.parse(l); } catch { return null; } })
        .filter(Boolean)
        .find((d: any) => d.episode?.toString() === episode.toString());
    } else {
      try { data = JSON.parse(lines[0]); } catch { data = null; }
    }

    if (data && data.url) {
      const epNum = episode ? episode.toString() : (data.episode?.toString() || '1');
      let cleanPath = data.url;

      cleanPath = cleanPath
        .replace(/\[type\]/g,    pluralType)
        .replace(/{type}/g,      pluralType)
        .replace(/\/movie\//g,   '/movies/')
        .replace(/\[prefix\]/g,  prefix)
        .replace(/{prefix}/g,    prefix)
        .replace(/\[id\]/g,      id)
        .replace(/{id}/g,        id)
        .replace(/{season}/g,    seasonPadded || '01')
        .replace(/{episode}/g,   epNum || '1');

      const isActuallyTV = type === 'tv' || cleanPath.includes('/tv/');
      if (!isActuallyTV) {
        cleanPath = cleanPath.replace(/\/s\d+\//g, '/');
      } else {
        if (!cleanPath.includes(`/s${seasonPadded}/`)) {
          cleanPath = cleanPath.replace(new RegExp(`/${id}/`, 'g'), `/${id}/s${seasonPadded}/`);
        }
      }

      // Normalise double-slashes
      if (cleanPath.includes('://')) {
        const parts = cleanPath.split('://');
        cleanPath = parts[0] + '://' + parts[1].replace(/\/\/+/g, '/');
      } else {
        cleanPath = cleanPath.replace(/\/\/+/g, '/');
      }
      cleanPath = cleanPath.replace(/^\/+/, '');

      // Select video CDN domain based on content id for consistent load distribution
      const videoDomain = getVideoDomain(id).replace(/\/$/, '');

      if (!cleanPath.startsWith('http')) {
        videoUrl = `${videoDomain}/${cleanPath}`;
      } else {
        // Replace existing domain in absolute URL with rotated domain
        try {
          const parsed = new URL(cleanPath);
          const rotated = new URL(videoDomain);
          parsed.hostname = rotated.hostname;
          videoUrl = parsed.toString();
        } catch {
          videoUrl = cleanPath;
        }
      }
    }
  }

  // Subtitle: only for foreign content (not Arabic)
  if (isForeign) {
    const videoDomain = getVideoDomain(id).replace(/\/$/, '');
    subtitleUrl = `${videoDomain}/${pluralType}/${prefix}/${id}/ar.vtt`;
  }

} catch (e) {
  console.error('[PlayerIsland] Error:', e);
}
---

<div class="aspect-video bg-black rounded-xl overflow-hidden shadow-2xl relative border border-zinc-800">
  {videoUrl ? (
    <PlyrComponent client:only="svelte" src={videoUrl} subtitle={isForeign ? subtitleUrl : ''} />
  ) : (
    <div class="absolute inset-0 flex items-center justify-center bg-zinc-900">
      <div class="flex flex-col items-center gap-4">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <p class="text-zinc-400">جاري تحميل الفيلم/الحلقة...</p>
        <p class="text-zinc-600 text-xs">إذا لم يظهر المشغل، تأكد من توفر ملف CDN</p>
      </div>
    </div>
  )}
</div>
